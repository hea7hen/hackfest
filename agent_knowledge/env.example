# Copy to .env in this folder (not committed).

# LM Studio (chat + embeddings — OpenAI-compatible API)
LM_STUDIO_URL=http://localhost:1234/v1
LM_STUDIO_MODEL=mlx-community/gemma-3-4b-it-4bit
# Embedding model id as shown in LM Studio (Load tab / server)
EMBED_MODEL=text-embedding-nomic-embed-text-v1.5
# Optional: separate base for embed script if ever different (defaults to LM_STUDIO_URL pattern)
# EMBED_URL=http://localhost:1234/v1

# Gemini Flash (cloud stage) — key from https://aistudio.google.com
GOOGLE_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-preview
